pipeline {
    agent any

    tools {
        jdk 'JAVA_HOME'
        maven 'M2_HOME'
    }

    environment {
        APP_NAME = "Blog"
        DOCKER_IMAGE = "vidancodex/pi2-blog-microservice"
        CD_JOB = "blog-cd"
    }

    stages {

        stage('Checkout') {
            steps {
                cleanWs()
                retry(3) {
                    checkout scm
                }
            }
        }

        stage('Build & Test') {
            steps {
                dir('blog-microservice') {
                    sh "mvn clean verify -DskipTests -Dmaven.test.failure.ignore=false"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('blog-microservice') {
                    withSonarQubeEnv('SonarQube') {
                        sh """
                            mvn sonar:sonar \
                            -Dsonar.projectKey=PI-SOYOSA-blog \
                            -Dsonar.projectName=PI-SOYOSA-blog-microservice \
                            -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                        """
                    }
                }
            }
        }

        stage('Package') {
            steps {
                dir('blog-microservice') {
                    sh "mvn package -DskipTests"
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('blog-microservice') {
                    sh "docker build -t ${DOCKER_IMAGE} ."
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                    sh """
                        echo $PASS | docker login -u $USER --password-stdin
                        docker push ${DOCKER_IMAGE}
                    """
                }
            }
        }

        stage('Trigger CD Pipeline') {
            steps {
                echo "🚀 Triggering CD pipeline..."
                build job: "${CD_JOB}", parameters: [string(name: 'DOCKER_TAG', value: 'latest')], wait: false
            }
        }
    }

    post {
        success {
            echo "✅ CI finished successfully!"
        }

        failure {
            echo "❌ CI failed!"
        }

        always {
            cleanWs()
        }
    }
}

