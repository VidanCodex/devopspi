pipeline {
    agent any

    parameters {
        string(name: 'DOCKER_TAG', defaultValue: 'latest', description: 'Docker image tag')
    }

    environment {
        SERVICE_NAME   = 'blog-microservice'
        DOCKER_IMAGE   = 'vidancodex/pi2-blog-microservice'
        NAMESPACE      = 'pi-soyosa'
        DEPLOYMENT     = 'blog-microservice-deployment'
        KUBECONFIG     = "/var/lib/jenkins/.kube/config"
        TAG            = "${params.DOCKER_TAG ?: 'latest'}"
        EMAIL_CREDS    = credentials('gmail-app-password')
    }

    stages {

        stage('Setup Monitoring') {
            steps {
                sh '''
                    kubectl apply -f monitoring/namespace.yaml
                    kubectl apply -f monitoring/prometheus-config.yaml
                    kubectl apply -f monitoring/prometheus-deployment.yaml
                    kubectl apply -f monitoring/grafana-deployment.yaml
                '''
            }
        }

        stage('Check Kubernetes') {
            steps {
                sh '''
                    kubectl cluster-info
                    kubectl get nodes
                '''
            }
        }

        stage('Pull Docker Image') {
            steps {
                sh "docker pull ${DOCKER_IMAGE}:${TAG}"
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                dir('blog-microservice') {

                    sh '''
                        kubectl apply -f blog-microservice-deployment.yaml
                        kubectl apply -f blog-microservice-service.yaml
                    '''

                    sh """
                        kubectl set image deployment/${DEPLOYMENT} \
                        blog-microservice=${DOCKER_IMAGE}:${TAG} \
                        -n ${NAMESPACE}
                    """

                    sh '''
                        kubectl rollout status deployment/${DEPLOYMENT} \
                        -n ${NAMESPACE} --timeout=120s
                    '''
                }
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                    kubectl get pods -n ${NAMESPACE}
                    kubectl get svc -n ${NAMESPACE}
                '''
            }
        }
    }

    post {

        success {
            emailext(
                subject: "Build SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: "The deployment completed successfully.\nCheck details: ${env.BUILD_URL}",
                to: "jomniyacine@gmail.com"
            )

            echo 'CD pipeline completed successfully!'
        }

        failure {
            emailext(
                subject: "Build FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: "The deployment failed.\nCheck logs: ${env.BUILD_URL}",
                to: "jomniyacine@gmail.com"
            )

            echo 'Deployment failed.'
        }
    }
}