pipeline {
    agent any

    parameters {
        string(name: 'DOCKER_TAG', defaultValue: 'latest', description: 'Docker image tag')
    }

    environment {
        SERVICE_NAME = 'courses-microservice'
        DOCKER_IMAGE = 'vidancodex/pi2-courses-microservice'
        NAMESPACE    = 'pi-soyosa'
        DEPLOYMENT   = 'courses-microservice-deployment'
    }

    stages {

        stage('Pre-check Kubernetes') {
            steps {
                sh '''
                    kubectl cluster-info
                    kubectl get nodes
                    kubectl get ns | grep -q ${NAMESPACE} || kubectl create ns ${NAMESPACE}
                '''
            }
        }

        stage('Deploy Config (Safe Apply)') {
            steps {
                dir('courses-microservice') {
                    sh '''
                        kubectl apply -n ${NAMESPACE} -f courses-microservice-deployment.yaml
                        kubectl apply -n ${NAMESPACE} -f courses-microservice-service.yaml
                    '''
                }
            }
        }

        stage('Update Image') {
            steps {
                sh '''
                    kubectl set image deployment/${DEPLOYMENT} \
                        ${SERVICE_NAME}=${DOCKER_IMAGE}:${DOCKER_TAG} \
                        -n ${NAMESPACE}

                    kubectl rollout restart deployment/${DEPLOYMENT} -n ${NAMESPACE}
                '''
            }
        }

        stage('Wait for Rollout (SAFE MODE)') {
            steps {
                sh '''
                    set +e

                    kubectl rollout status deployment/${DEPLOYMENT} \
                        -n ${NAMESPACE} --timeout=180s

                    EXIT_CODE=$?

                    if [ $EXIT_CODE -ne 0 ]; then
                        echo "❌ Rollout failed or stuck. Debugging..."

                        echo "=== PODS ==="
                        kubectl get pods -n ${NAMESPACE}

                        echo "=== DESCRIBE DEPLOYMENT ==="
                        kubectl describe deployment/${DEPLOYMENT} -n ${NAMESPACE}

                        echo "=== EVENTS ==="
                        kubectl get events -n ${NAMESPACE} --sort-by=.metadata.creationTimestamp | tail -20

                        exit 1
                    fi
                '''
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                    kubectl get pods -n ${NAMESPACE}
                    kubectl get svc -n ${NAMESPACE}
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Deployment successful"
        }

        failure {
            sh '''
                echo "⚠️ Rollback attempt..."

                kubectl rollout undo deployment/${DEPLOYMENT} -n ${NAMESPACE} || true
            '''
        }

        always {
            cleanWs()
        }
    }
}

